{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build SimpleRPG (javac)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/SimpleRPG/.vscode/build.ps1"
      ],
      "options": { "cwd": "${workspaceFolder}/SimpleRPG" },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    }
  ]
}
